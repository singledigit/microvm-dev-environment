# iPad Claude Code — deployment config
# Copy to config.env and fill in your values. config.env is git-ignored.

# AWS account you're deploying into (12 digits).
AWS_ACCOUNT=<your-account-id>

# AWS region. MicroVMs + S3 Files must be in the same region.
AWS_REGION=us-east-1

# Named AWS CLI profile to use. "default" if you don't use named profiles.
AWS_PROFILE=default

# S3 Files filesystem ID (fs-...). OPTIONAL — leave blank and the CDK stack
# creates the filesystem for you. Set it only to reuse an existing filesystem.
S3_FILES_FS_ID=

# MicroVM image name (any label; the deploy reuses/updates it).
IMAGE_NAME=ipad-claude-v2

# MicroVM memory in MB.
MVM_MEMORY=8192

# Cosmetic only — shown on the login screen. The token Lambda validates the
# PASSWORD (auto-generated into SSM on first deploy), never the email.
LOGIN_EMAIL=you@example.com
