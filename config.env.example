# iPad Claude Code — deployment config
# Copy to config.env and fill in your values. config.env is git-ignored.

# AWS account you're deploying into (12 digits).
AWS_ACCOUNT=<your-account-id>

# AWS region. The whole stack (MicroVMs + S3 Files) lives here.
AWS_REGION=us-east-1

# Named AWS CLI profile to use. "default" if you don't use named profiles.
AWS_PROFILE=default

# CloudFormation/SAM stack name.
STACK_NAME=ipad-claude

# MicroVM image name (any label; the deploy reuses/updates it).
IMAGE_NAME=ipad-claude-v2

# MicroVM memory in MB.
MVM_MEMORY=8192

# Cosmetic only — the email shown in the deploy summary's create-user command.
# Auth is Cognito (admin-created users); this is not a credential.
LOGIN_EMAIL=you@example.com
