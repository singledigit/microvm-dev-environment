export HOME=/home/coder
export PATH="$HOME/.npm-global/bin:$HOME/.local/bin:/opt/uv/toolbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
# npm -g installs land in the persistent home (the image prefix /usr is
# root-owned and resets on recycle). pip needs no equivalent: it auto-falls
# back to --user (~/.local) when site-packages isn't writable.
export NPM_CONFIG_PREFIX="$HOME/.npm-global"
export CLAUDE_CODE_USE_BEDROCK=1
export AWS_REGION=us-east-1
# Default model: Opus. Fable available via /model us.anthropic.claude-fable-5.
export ANTHROPIC_MODEL=us.anthropic.claude-opus-4-8
export ANTHROPIC_DEFAULT_OPUS_MODEL=us.anthropic.claude-opus-4-8
export ANTHROPIC_DEFAULT_SONNET_MODEL=us.anthropic.claude-sonnet-5
export ANTHROPIC_DEFAULT_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
export ANTHROPIC_SMALL_FAST_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
# uv/uvx state on the hardlink-capable system FS (NFS home rejects hardlinks).
# Lets the AWS toolkit's `uvx`-launched MCP proxy run from the warmed cache.
export UV_CACHE_DIR=/opt/uv/cache
export UV_PYTHON_INSTALL_DIR=/opt/uv/python
export UV_TOOL_DIR=/opt/uv/tool
export UV_TOOL_BIN_DIR=/opt/uv/toolbin

# Prompt: green coder@claude : blue cwd $
PROMPT='%F{green}coder@claude%f:%F{blue}%~%f$ '

# History on the persistent home
export HISTFILE=/home/coder/.zsh_history
export HISTSIZE=10000
export SAVEHIST=10000
setopt SHARE_HISTORY INC_APPEND_HISTORY

cd /home/coder
echo ""
echo "  Claude Code sandbox  •  type 'claude' to start"
echo "  Workspace: /home/coder/workspace  (persistent S3 storage)"
echo ""
